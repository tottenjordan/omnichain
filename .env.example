# ============================================
# OmniChain Environment Configuration (example)
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================

# 1. Google Cloud Platform Settings
PROJECT_ID=your-project-id
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_PROJECT_NUMBER=000000000000
GCP_REGION=us-central1
GOOGLE_CLOUD_LOCATION=global

# Set to 1 to route google-genai through Vertex AI; 0 uses the Gemini Developer API (API key).
GOOGLE_GENAI_USE_VERTEXAI=0

# 2. Model & Developer API Authentication (only needed when USE_VERTEXAI=0)
GOOGLE_API_KEY=your-api-key
GEMINI_API_KEY=your-api-key

# 3. Cloud Storage Resource
GCS_BUCKET_NAME=omnichain-media-${PROJECT_ID}
BUCKET=gs://${GCS_BUCKET_NAME}
GOOGLE_CLOUD_STORAGE_BUCKET=${GCS_BUCKET_NAME}

# 4. Models (optional overrides)
STORYBOARD_MODEL=gemini-3.6-flash
OMNI_MODEL=gemini-omni-flash-preview
